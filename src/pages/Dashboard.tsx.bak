import { useState, useEffect, useCallback, useRef } from "react";
import { useNavigate, useLocation } from "react-router-dom";
import { Menu, ArrowUp, Plus, Paperclip, X, ChevronRight, Check, Square } from "lucide-react";
import { supabase } from "../lib/supabaseClient";
import { useThinking } from "../context/Thinkingcontext";
import "../styles/dashboard-ui.css";
import "../styles/theme-dark.css";  
import "../styles/theme-pink.css";
import "../styles/theme-switcher.css";
import "../styles/theme-ocean.css";
import "../styles/theme-forest.css";
import "../styles/theme-sand.css";

const ROOT_COLLAPSED_CLASS = "cora-sidebar-collapsed";
const LS_KEY = "cora.sidebarCollapsed";

// ============================================================================
// TYPES
// ============================================================================

interface PastedContent {
  id: string;
  content: string;
}

interface Message {
  id: string;
  text: string;
  sender: "user" | "ai";
  createdAt: string;
  pastedContents?: PastedContent[];
}

interface Session {
  id: string;
  title: string;
  createdAt: string;
  messages: Message[];
}

// HITL Types
interface QuestionOption {
  label: string;
  value: string;
}

interface ClarificationQuestion {
  id: string;
  question: string;
  options?: QuestionOption[];
  type: "choice" | "text";
}

// Timeline Types
interface TimelineEvent {
  id: string;
  node: string;
  message: string;
  timestamp: string;
  isActive?: boolean;
}

// Follow-up Suggestions
interface FollowUpSuggestion {
  id: string;
  text: string;
}

// ============================================================================
// PARTICLE GRID - Flashlight effect with thinking pulse
// ============================================================================

interface Dot {
  x: number;
  y: number;
  baseX: number;
  baseY: number;
}

interface ParticleGridProps {
  containerRef: React.RefObject<HTMLDivElement>;
  isThinking?: boolean;
}

function ParticleGrid({ containerRef, isThinking = false }: ParticleGridProps) {
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const mouseRef = useRef({ x: -200, y: -200 });
  const targetRef = useRef({ x: -200, y: -200 });
  const dotsRef = useRef<Dot[]>([]);
  const animationRef = useRef<number | null>(null);
  const isInsideRef = useRef(false);
  const containerSizeRef = useRef({ width: 0, height: 0 });
  const pulsePhaseRef = useRef(0);
  const isThinkingRef = useRef(isThinking);
  const timeRef = useRef(0);
  const waveCentersRef = useRef<{x: number, y: number, phase: number, speed: number}[]>([]);

  // Update thinking ref when prop changes
  useEffect(() => {
    isThinkingRef.current = isThinking;
  }, [isThinking]);

  useEffect(() => {
    const canvas = canvasRef.current;
    const container = containerRef.current;
    if (!canvas || !container) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const GRID_SPACING = 20;
    const INFLUENCE_RADIUS = 120;
    const PUSH_STRENGTH = 35;
    const BASE_VISIBILITY_RADIUS = 150;
    
    // Thinking pulse parameters - MORE DRAMATIC
    const PULSE_MIN_RADIUS = 120;
    const PULSE_MAX_RADIUS = 350;
    const PULSE_SPEED = 0.06;
    const PULSE_OPACITY_BOOST = 0.6;
    const PULSE_SIZE_BOOST = 1.2;
    
    // Ambient wave parameters
    const WAVE_COUNT = 3;
    const WAVE_RADIUS = 200;

    const setupCanvas = () => {
      const rect = container.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      canvas.style.width = `${rect.width}px`;
      canvas.style.height = `${rect.height}px`;
      ctx.scale(dpr, dpr);

      containerSizeRef.current = { width: rect.width, height: rect.height };

      const dots: Dot[] = [];
      for (let x = GRID_SPACING; x < rect.width; x += GRID_SPACING) {
        for (let y = GRID_SPACING; y < rect.height; y += GRID_SPACING) {
          dots.push({ x, y, baseX: x, baseY: y });
        }
      }
      dotsRef.current = dots;
      
      // Initialize wave centers at random positions
      waveCentersRef.current = [];
      for (let i = 0; i < WAVE_COUNT; i++) {
        waveCentersRef.current.push({
          x: Math.random() * rect.width,
          y: Math.random() * rect.height,
          phase: Math.random() * Math.PI * 2,
          speed: 0.006 + Math.random() * 0.006
        });
      }
    };

    setupCanvas();

    const handleMouseMove = (e: MouseEvent) => {
      const rect = container.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      
      isInsideRef.current = x >= 0 && x <= rect.width && y >= 0 && y <= rect.height;
      
      if (isInsideRef.current) {
        targetRef.current = { x, y };
        document.body.style.cursor = 'none';
      } else {
        targetRef.current = { x: -200, y: -200 };
        document.body.style.cursor = 'auto';
      }
    };

    const handleMouseLeave = () => {
      isInsideRef.current = false;
      targetRef.current = { x: -200, y: -200 };
      document.body.style.cursor = 'auto';
    };

    const handleResize = () => {
      setupCanvas();
    };

    window.addEventListener("mousemove", handleMouseMove);
    container.addEventListener("mouseleave", handleMouseLeave);
    window.addEventListener("resize", handleResize);

    const animate = () => {
      const { width, height } = containerSizeRef.current;
      ctx.clearRect(0, 0, width, height);

      const ease = 0.12;
      const dots = dotsRef.current;
      const thinking = isThinkingRef.current;
      
      // Update time for ambient animation
      timeRef.current += 1;

      // Update pulse phase when thinking
      if (thinking) {
        pulsePhaseRef.current += PULSE_SPEED;
      }
      
      // Update wave centers (slowly move them around)
      waveCentersRef.current.forEach(wave => {
        wave.phase += wave.speed;
        // Slowly drift the wave centers
        wave.x += Math.sin(wave.phase * 0.3) * 0.15;
        wave.y += Math.cos(wave.phase * 0.4) * 0.15;
        // Keep within bounds
        if (wave.x < 0) wave.x = width;
        if (wave.x > width) wave.x = 0;
        if (wave.y < 0) wave.y = height;
        if (wave.y > height) wave.y = 0;
      });

      // Calculate pulsing visibility radius
      const pulseValue = Math.sin(pulsePhaseRef.current);
      const pulseNormalized = (pulseValue + 1) / 2; // 0 to 1
      const VISIBILITY_RADIUS = thinking 
        ? PULSE_MIN_RADIUS + (PULSE_MAX_RADIUS - PULSE_MIN_RADIUS) * pulseNormalized
        : BASE_VISIBILITY_RADIUS;
      
      // Extra opacity when thinking and at pulse peak
      const thinkingOpacityBoost = thinking ? PULSE_OPACITY_BOOST * pulseNormalized : 0;

      // Determine the light source position
      let lightX: number;
      let lightY: number;
      
      // When thinking, always center the light
      if (thinking) {
        const centerX = width / 2;
        const centerY = height / 2;
        mouseRef.current.x += (centerX - mouseRef.current.x) * ease;
        mouseRef.current.y += (centerY - mouseRef.current.y) * ease;
        lightX = mouseRef.current.x;
        lightY = mouseRef.current.y;
      } else if (isInsideRef.current) {
        mouseRef.current.x += (targetRef.current.x - mouseRef.current.x) * ease;
        mouseRef.current.y += (targetRef.current.y - mouseRef.current.y) * ease;
        lightX = mouseRef.current.x;
        lightY = mouseRef.current.y;
      } else {
        // No hover - use ambient waves
        lightX = -1000;
        lightY = -1000;
      }

      for (let i = 0; i < dots.length; i++) {
        const dot = dots[i];
        let opacity = 0;
        let dotSize = 1.2;

        // Check if mouse/thinking light affects this dot
        if (isInsideRef.current || thinking) {
          const dx = dot.baseX - lightX;
          const dy = dot.baseY - lightY;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < VISIBILITY_RADIUS) {
            const visibilityFactor = 1 - (dist / VISIBILITY_RADIUS);
            opacity = Math.pow(visibilityFactor, 1.5) * 0.6;
            
            // Add opacity boost when thinking
            if (thinking) {
              opacity = Math.min(1, opacity + thinkingOpacityBoost * visibilityFactor * 1.5);
              dotSize = 1.5 + PULSE_SIZE_BOOST * pulseNormalized * visibilityFactor;
            }

            // Push effect when hovering
            if (!thinking && isInsideRef.current && dist < INFLUENCE_RADIUS) {
              const normalizedDist = dist / INFLUENCE_RADIUS;
              const force = Math.pow(1 - normalizedDist, 2) * PUSH_STRENGTH;
              const angle = Math.atan2(dy, dx);
              dot.x = dot.baseX + Math.cos(angle) * force;
              dot.y = dot.baseY + Math.sin(angle) * force;
            } else {
              dot.x += (dot.baseX - dot.x) * 0.1;
              dot.y += (dot.baseY - dot.y) * 0.1;
            }
          }
        }
        
        // Ambient wave animation when no hover and not thinking
        if (!isInsideRef.current && !thinking) {
          let waveOpacity = 0;
          
          waveCentersRef.current.forEach(wave => {
            const dx = dot.baseX - wave.x;
            const dy = dot.baseY - wave.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            
            // Create expanding ring effect
            const ringRadius = (Math.sin(wave.phase) + 1) * WAVE_RADIUS;
            const ringWidth = 80;
            const distFromRing = Math.abs(dist - ringRadius);
            
            if (distFromRing < ringWidth) {
              const ringFactor = 1 - (distFromRing / ringWidth);
              waveOpacity = Math.max(waveOpacity, ringFactor * 0.25);
            }
          });
          
          opacity = waveOpacity;
          dot.x += (dot.baseX - dot.x) * 0.1;
          dot.y += (dot.baseY - dot.y) * 0.1;
        }

        if (opacity > 0.02) {
          ctx.beginPath();
          ctx.arc(dot.x, dot.y, dotSize, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255, 255, 255, ${opacity})`;
          ctx.fill();
        } else {
          dot.x += (dot.baseX - dot.x) * 0.1;
          dot.y += (dot.baseY - dot.y) * 0.1;
        }
      }

      // Draw custom cursor only when mouse is inside and NOT thinking
      if (!thinking && isInsideRef.current && lightX > 0 && lightY > 0) {
        const color = "rgba(255, 255, 255, 0.85)";
        const size = 16;
        const innerGap = 4;
        const cornerLength = 6;

        ctx.strokeStyle = color;
        ctx.lineWidth = 1.5;
        ctx.lineCap = "square";

        ctx.beginPath();
        ctx.moveTo(lightX - size, lightY - size + cornerLength);
        ctx.lineTo(lightX - size, lightY - size);
        ctx.lineTo(lightX - size + cornerLength, lightY - size);
        ctx.stroke();

        ctx.beginPath();
        ctx.moveTo(lightX + size - cornerLength, lightY - size);
        ctx.lineTo(lightX + size, lightY - size);
        ctx.lineTo(lightX + size, lightY - size + cornerLength);
        ctx.stroke();

        ctx.beginPath();
        ctx.moveTo(lightX - size, lightY + size - cornerLength);
        ctx.lineTo(lightX - size, lightY + size);
        ctx.lineTo(lightX - size + cornerLength, lightY + size);
        ctx.stroke();

        ctx.beginPath();
        ctx.moveTo(lightX + size - cornerLength, lightY + size);
        ctx.lineTo(lightX + size, lightY + size);
        ctx.lineTo(lightX + size, lightY + size - cornerLength);
        ctx.stroke();

        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(lightX, lightY - size + 5);
        ctx.lineTo(lightX, lightY - innerGap);
        ctx.moveTo(lightX, lightY + innerGap);
        ctx.lineTo(lightX, lightY + size - 5);
        ctx.moveTo(lightX - size + 5, lightY);
        ctx.lineTo(lightX - innerGap, lightY);
        ctx.moveTo(lightX + innerGap, lightY);
        ctx.lineTo(lightX + size - 5, lightY);
        ctx.stroke();

        ctx.beginPath();
        ctx.arc(lightX, lightY, 1.5, 0, Math.PI * 2);
        ctx.fillStyle = color;
        ctx.fill();
      }

      animationRef.current = requestAnimationFrame(animate);
    };

    animationRef.current = requestAnimationFrame(animate);

    return () => {
      window.removeEventListener("mousemove", handleMouseMove);
      container.removeEventListener("mouseleave", handleMouseLeave);
      window.removeEventListener("resize", handleResize);
      document.body.style.cursor = 'auto';
      if (animationRef.current) {
        cancelAnimationFrame(animationRef.current);
      }
    };
  }, [containerRef]);

  return (
    <canvas
      ref={canvasRef}
      style={{
        position: "absolute",
        top: 0,
        left: 0,
        width: "100%",
        height: "100%",
        pointerEvents: "none",
      }}
    />
  );
}

// ============================================================================
// TIMELINE COMPONENT - Single line that updates
// ============================================================================

interface TimelineProps {
  events: TimelineEvent[];
  isLoading?: boolean;
}

function Timeline({ events, isLoading = false }: TimelineProps) {
  if (events.length === 0) return null;
  
  // Get the latest event
  const latestEvent = events[events.length - 1];
  
  return (
    <div className="dash_timelineSingle">
      <div className={`dash_timelineDotSingle ${isLoading ? "dash_timelineDotSingle--active" : ""}`} />
      <div className="dash_timelineSingleContent">
        <span className="dash_timelineSingleNode">{latestEvent.node}</span>
        <span className="dash_timelineSingleMsg">{latestEvent.message}</span>
      </div>
    </div>
  );
}

// ============================================================================
// HITL WIZARD - Clarification questions with wizard flow
// ============================================================================

interface HITLWizardProps {
  questions: ClarificationQuestion[];
  currentIndex: number;
  answers: Record<string, string>;
  onAnswer: (questionId: string, answer: string) => void;
  onSkip: (questionId: string) => void;
  onComplete: () => void;
}

function HITLWizard({ 
  questions, 
  currentIndex, 
  onAnswer, 
  onSkip,
  onComplete 
}: HITLWizardProps) {
  const [textAnswer, setTextAnswer] = useState("");
  
  if (questions.length === 0) return null;
  
  // Check if all questions answered
  if (currentIndex >= questions.length) {
    return (
      <div className="dash_hitlComplete">
        <div className="dash_hitlCompleteIcon">
          <Check size={24} />
        </div>
        <p>All questions answered</p>
        <button 
          type="button" 
          className="dash_hitlSubmitBtn"
          onClick={onComplete}
        >
          Continue
          <ChevronRight size={16} />
        </button>
      </div>
    );
  }
  
  const currentQ = questions[currentIndex];
  const progress = (currentIndex / questions.length) * 100;
  
  const handleOptionSelect = (value: string) => {
    onAnswer(currentQ.id, value);
  };
  
  const handleTextSubmit = () => {
    if (textAnswer.trim()) {
      onAnswer(currentQ.id, textAnswer.trim());
      setTextAnswer("");
    }
  };
  
  const handleSkip = () => {
    onSkip(currentQ.id);
    setTextAnswer("");
  };
  
  return (
    <div className="dash_hitlWizard">
      <div className="dash_hitlCard">
        <div className="dash_hitlHeader">
          <span className="dash_hitlLabel">
            QUESTION {currentIndex + 1} OF {questions.length}
          </span>
        </div>
        
        <div className="dash_hitlQuestion">
          {currentQ.question}
        </div>
        
        <div className="dash_hitlProgress">
          <span className="dash_hitlProgressLabel">Progress</span>
          <div className="dash_hitlProgressBar">
            <div 
              className="dash_hitlProgressFill" 
              style={{ width: `${progress}%` }} 
            />
          </div>
          <span className="dash_hitlProgressCount">
            {currentIndex + 1}/{questions.length}
          </span>
        </div>
        
        {/* Options or text input */}
        {currentQ.options && currentQ.options.length > 0 ? (
          <div className="dash_hitlOptions">
            {currentQ.options.map((option, idx) => (
              <button
                key={option.value}
                type="button"
                className={`dash_hitlOption ${idx === 0 ? "dash_hitlOption--primary" : ""}`}
                onClick={() => handleOptionSelect(option.value)}
              >
                {option.label}
              </button>
            ))}
          </div>
        ) : (
          <div className="dash_hitlTextInput">
            <textarea
              value={textAnswer}
              onChange={(e) => setTextAnswer(e.target.value)}
              placeholder="Type your answer here..."
              className="dash_hitlTextarea"
              rows={3}
            />
            <div className="dash_hitlTextActions">
              <button
                type="button"
                className="dash_hitlContinueBtn"
                onClick={handleTextSubmit}
                disabled={!textAnswer.trim()}
              >
                Continue
              </button>
              <button
                type="button"
                className="dash_hitlSkipBtn"
                onClick={handleSkip}
              >
                Skip question
              </button>
            </div>
          </div>
        )}
      </div>
      <p className="dash_hitlLegend">Sentinela will continue after your answer</p>
    </div>
  );
}

// ============================================================================
// FOLLOW-UP SUGGESTIONS - Clickable suggestion buttons
// ============================================================================

interface SuggestionsProps {
  suggestions: FollowUpSuggestion[];
  onSelect: (suggestion: string) => void;
}

function FollowUpSuggestions({ suggestions, onSelect }: SuggestionsProps) {
  if (suggestions.length === 0) return null;
  
  return (
    <div className="dash_suggestions">
      <div className="dash_suggestionsTitle">
        Suggested follow-up questions
      </div>
      <div className="dash_suggestionsList">
        {suggestions.map((suggestion) => (
          <button
            key={suggestion.id}
            type="button"
            className="dash_suggestionBtn"
            onClick={() => onSelect(suggestion.text)}
          >
            <span>{suggestion.text}</span>
            <ChevronRight size={16} className="dash_suggestionArrow" />
          </button>
        ))}
      </div>
    </div>
  );
}

